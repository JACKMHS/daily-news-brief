# Daily AI Brief - environment configuration
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# -- LLM (required) -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Optional: switch model
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   (default - fast, cheap)
# ANTHROPIC_MODEL=claude-sonnet-4-6           (richer summaries, ~10x cost)

# -- Push mode (choose one) ---------------------------------------------------
# "serverchan"  -> Server Chan (FTQQ) - default
# "wecom"       -> WeCom (Enterprise WeChat) webhook
PUSH_MODE=serverchan

# Option A: Server Chan - get your SCT key at https://sct.ftqq.com/
SERVERCHAN_KEY=SCT...

# Option B: WeCom webhook
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# -- Optional tuning ----------------------------------------------------------
# TOP_N=5               # articles per brief
# MAX_AGE_HOURS=48      # ignore articles older than this
# DEDUP_THRESHOLD=0.55  # Jaccard similarity threshold for dedup
# MAX_INPUT_CHARS=3000  # max chars sent to Claude per article
# LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# -- Custom feeds (optional, comma-separated) ---------------------------------
# RSS_FEEDS=https://techcrunch.com/feed/,https://rss.arxiv.org/rss/cs.AI

# -- Extra keywords to boost in ranking (optional) ----------------------------
# AI_KEYWORDS=ai,llm,openai,gpt,claude,gemini,research,agent
